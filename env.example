OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TEMPERATURE=0
CHAT_API_PORT=3001
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=dIAna sales agent

# Si true, cada POST /api/chat devuelve trace (modelo + herramientas) como en body { "debug": true }.
AGENT_TRACE=false

# Tienda / API de comercio (herramienta http_get_api_tienda). URL obligatoria para consultar.
STORE_BASE_URL=https://traveldiary2026.basmi.co/
STORE_TIMEOUT_MS=12000
STORE_MAX_RESPONSE_CHARS=48000
# Máximo de enlaces xlink:href a resolver por petición (listados XML PrestaShop).
STORE_XLINK_MAX_FOLLOWS=30
# Opcional: clave del webservice PrestaShop.
STORE_WS_KEY=
